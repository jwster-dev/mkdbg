    p_asm = sub.add_parser("asm", help="assemble .asm -> .bin")
    p_asm.add_argument("args", nargs=argparse.REMAINDER)

    p_dis = sub.add_parser("disasm", help="disassemble .bin -> asm listing")
    p_dis.add_argument("args", nargs=argparse.REMAINDER)

    p_load = sub.add_parser("load", help="load .bin over UART")
    p_load.add_argument("args", nargs=argparse.REMAINDER)

    p_tc = sub.add_parser("tinyc", help="compile tiny C -> asm")
    p_tc.add_argument("args", nargs=argparse.REMAINDER)

    p_verify = sub.add_parser("verify", help="verify bounded CFG profile on .bin")
    p_verify.add_argument("args", nargs=argparse.REMAINDER)

    p_demo = sub.add_parser("demo", help="end-to-end demo script")
    p_demo.add_argument("args", nargs=argparse.REMAINDER)

    p_batch = sub.add_parser("batch", help="run vm32 commands from batch file")
