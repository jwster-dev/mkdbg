    p_triage.add_argument("--baud", type=int, help="UART baud rate")
    p_triage.add_argument("--char-delay-ms", type=float, help="per-char TX delay in ms")
    p_triage.add_argument("--snapshot-timeout-s", type=float, help="snapshot timeout seconds")
