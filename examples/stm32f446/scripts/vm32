        extra = ["--port", ns.port]
        if ns.baud is not None:
            extra.extend(["--baud", str(ns.baud)])
        if ns.char_delay_ms is not None:
            extra.extend(["--char-delay-ms", str(ns.char_delay_ms)])
        if ns.retries is not None:
            extra.extend(["--retries", str(ns.retries)])
        if ns.no_reset:
            extra.append("--no-reset")
        if ns.skip_mpu_overflow:
            extra.append("--skip-mpu-overflow")
        if ns.inner_json:
            extra.append("--json")
        return run_tool(ns.cmd, extra, ns.json)
    if ns.cmd == "sonic-regress":
        extra = ["--port", ns.port]
        if ns.baud is not None:
            extra.extend(["--baud", str(ns.baud)])
        if ns.char_delay_ms is not None:
            extra.extend(["--char-delay-ms", str(ns.char_delay_ms)])
        if ns.retries is not None:
            extra.extend(["--retries", str(ns.retries)])
        if ns.no_reset:
            extra.append("--no-reset")
        if ns.inner_json:
            extra.append("--json")
        return run_tool(ns.cmd, extra, ns.json)
    if ns.cmd == "kdi-regress":
        extra = ["--port", ns.port]
        if ns.baud is not None:
            extra.extend(["--baud", str(ns.baud)])
        if ns.char_delay_ms is not None:
            extra.extend(["--char-delay-ms", str(ns.char_delay_ms)])
        if ns.retries is not None:
            extra.extend(["--retries", str(ns.retries)])
        if ns.no_reset:
            extra.append("--no-reset")
        if ns.flash:
            extra.append("--flash")
        if ns.flash_skip_build:
            extra.append("--flash-skip-build")
        if ns.no_auto_flash_stale:
            extra.append("--no-auto-flash-stale")
        if ns.inner_json:
            extra.append("--json")
        return run_tool(ns.cmd, extra, ns.json)
    if ns.cmd == "irq-regress":
        extra = ["--port", ns.port]
        if ns.baud is not None:
            extra.extend(["--baud", str(ns.baud)])
        if ns.char_delay_ms is not None:
            extra.extend(["--char-delay-ms", str(ns.char_delay_ms)])
        if ns.retries is not None:
            extra.extend(["--retries", str(ns.retries)])
        if ns.no_reset:
            extra.append("--no-reset")
        if ns.flash:
            extra.append("--flash")
        if ns.flash_skip_build:
            extra.append("--flash-skip-build")
        if ns.no_auto_flash_stale:
            extra.append("--no-auto-flash-stale")
        if ns.inner_json:
            extra.append("--json")
        return run_tool(ns.cmd, extra, ns.json)
    if ns.cmd == "bringup-regress":
        extra = ["--port", ns.port]
        if ns.baud is not None:
            extra.extend(["--baud", str(ns.baud)])
        if ns.char_delay_ms is not None:
            extra.extend(["--char-delay-ms", str(ns.char_delay_ms)])
        if ns.retries is not None:
            extra.extend(["--retries", str(ns.retries)])
        if ns.no_reset:
            extra.append("--no-reset")
        if ns.flash:
            extra.append("--flash")
        if ns.flash_skip_build:
            extra.append("--flash-skip-build")
        if ns.no_auto_flash_stale:
            extra.append("--no-auto-flash-stale")
        if ns.inner_json:
            extra.append("--json")
        return run_tool(ns.cmd, extra, ns.json)
    if ns.cmd == "bringup-ui":
        extra = []
        if ns.port is not None:
            extra.extend(["--port", ns.port])
        if ns.bundle_json is not None:
            extra.extend(["--bundle-json", ns.bundle_json])
        if ns.source_log is not None:
            extra.extend(["--source-log", ns.source_log])
        if ns.baud is not None:
            extra.extend(["--baud", str(ns.baud)])
        if ns.char_delay_ms is not None:
            extra.extend(["--char-delay-ms", str(ns.char_delay_ms)])
        if ns.snapshot_timeout_s is not None:
            extra.extend(["--snapshot-timeout-s", str(ns.snapshot_timeout_s)])
        if ns.auto_refresh_s is not None:
            extra.extend(["--auto-refresh-s", str(ns.auto_refresh_s)])
        if ns.target_driver is not None:
            extra.extend(["--target-driver", ns.target_driver])
        if ns.render_once:
            extra.append("--render-once")
        if ns.width is not None:
            extra.extend(["--width", str(ns.width)])
        if ns.height is not None:
            extra.extend(["--height", str(ns.height)])
        return run_tool(ns.cmd, extra, ns.json)
    if ns.cmd == "triage-bundle":
        extra = []
        if ns.port is not None:
            extra.extend(["--port", ns.port])
        if ns.source_log is not None:
            extra.extend(["--source-log", ns.source_log])
        if ns.baud is not None:
            extra.extend(["--baud", str(ns.baud)])
        if ns.char_delay_ms is not None:
            extra.extend(["--char-delay-ms", str(ns.char_delay_ms)])
        if ns.snapshot_timeout_s is not None:
            extra.extend(["--snapshot-timeout-s", str(ns.snapshot_timeout_s)])
        if ns.target_driver is not None:
            extra.extend(["--target-driver", ns.target_driver])
        if ns.output is not None:
            extra.extend(["--output", ns.output])
        if ns.inner_json:
            extra.append("--json")
        return run_tool(ns.cmd, extra, ns.json)
    if ns.cmd == "profile-regress":
        extra = ["--port", ns.port]
        if ns.baud is not None:
            extra.extend(["--baud", str(ns.baud)])
        if ns.char_delay_ms is not None:
            extra.extend(["--char-delay-ms", str(ns.char_delay_ms)])
        if ns.retries is not None:
            extra.extend(["--retries", str(ns.retries)])
        if ns.no_reset:
            extra.append("--no-reset")
        if ns.inner_json:
            extra.append("--json")
        return run_tool(ns.cmd, extra, ns.json)
    if ns.cmd == "profile-compare":
        extra = ["--baseline", ns.baseline, "--candidate", ns.candidate]
        if ns.baseline_index is not None:
            extra.extend(["--baseline-index", str(ns.baseline_index)])
        if ns.candidate_index is not None:
            extra.extend(["--candidate-index", str(ns.candidate_index)])
        if ns.driver is not None:
            for driver in ns.driver:
                extra.extend(["--driver", driver])
        if ns.period_compare:
            extra.append("--period-compare")
        if ns.dist_shift_threshold_pct is not None:
            extra.extend(["--dist-shift-threshold-pct", str(ns.dist_shift_threshold_pct)])
        if ns.dist_new_bin_pct is not None:
            extra.extend(["--dist-new-bin-pct", str(ns.dist_new_bin_pct)])
        if ns.jitter_min_delta is not None:
            extra.extend(["--jitter-min-delta", str(ns.jitter_min_delta)])
        if ns.jitter_rate_delta_pct is not None:
            extra.extend(["--jitter-rate-delta-pct", str(ns.jitter_rate_delta_pct)])
        if ns.loop_min_delta is not None:
            extra.extend(["--loop-min-delta", str(ns.loop_min_delta)])
        if ns.baseline_label is not None:
            extra.extend(["--baseline-label", ns.baseline_label])
        if ns.candidate_label is not None:
            extra.extend(["--candidate-label", ns.candidate_label])
        if ns.fail_on_regression:
            extra.append("--fail-on-regression")
        if ns.inner_json:
            extra.append("--json")
        return run_tool(ns.cmd, extra, ns.json)
    return run_tool(ns.cmd, ns.args, ns.json)


if __name__ == "__main__":
    raise SystemExit(main())
