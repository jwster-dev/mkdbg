    p_profile_compare.add_argument("--candidate", required=True, help="candidate profile log/jsonl file")
    p_profile_compare.add_argument("--baseline-index", type=int, help="baseline snapshot index (default: latest)")
    p_profile_compare.add_argument("--candidate-index", type=int, help="candidate snapshot index (default: latest)")
    p_profile_compare.add_argument("--driver", action="append", help="driver name (repeatable)")
    p_profile_compare.add_argument("--period-compare", action="store_true", help="compare baseline period vs candidate-baseline delta")
    p_profile_compare.add_argument("--dist-shift-threshold-pct", type=int, help="distribution shift TVD threshold percent")
    p_profile_compare.add_argument("--dist-new-bin-pct", type=int, help="new-bin probability mass threshold percent")
    p_profile_compare.add_argument("--jitter-min-delta", type=int, help="minimum jitter-transition increase to flag")
    p_profile_compare.add_argument("--jitter-rate-delta-pct", type=int, help="minimum jitter-rate increase percent to flag")
    p_profile_compare.add_argument("--loop-min-delta", type=int, help="minimum state-loop increase to flag")
    p_profile_compare.add_argument("--baseline-label", help="baseline label for explanation")
    p_profile_compare.add_argument("--candidate-label", help="candidate label for explanation")
    p_profile_compare.add_argument("--fail-on-regression", action="store_true", help="return non-zero if any regression is detected")
    p_profile_compare.add_argument("--inner-json", action="store_true", help="pass --json to driver_profile_compare.py")

    p_profile_regress = sub.add_parser("profile-regress", help="run on-board driver profile comparison regression workflow")
    p_profile_regress.add_argument("--port", required=True, help="serial port, e.g. /dev/cu.usbmodemXXXX")
    p_profile_regress.add_argument("--baud", type=int, help="UART baud rate")
    p_profile_regress.add_argument("--char-delay-ms", type=float, help="per-char TX delay in ms")
    p_profile_regress.add_argument("--retries", type=int, help="retry count per step on mismatch")
    p_profile_regress.add_argument("--no-reset", action="store_true", help="skip OpenOCD reset before test")
    p_profile_regress.add_argument("--inner-json", action="store_true", help="pass --json to driver_profile_compare_regress.py")

