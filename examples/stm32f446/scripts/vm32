#!/usr/bin/env python3
import argparse
import json
import shlex
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent
TOOLS = {
    "asm": ROOT / "vm32_asm.py",
    "disasm": ROOT / "vm32_disasm.py",
    "load": ROOT / "vm32_load.py",
    "tinyc": ROOT / "vm32_tinyc.py",
    "verify": ROOT / "vm32_verify.py",
    "board-regress": ROOT / "board_regress.py",
    "sonic-regress": ROOT / "sonic_regress.py",
    "kdi-regress": ROOT / "kdi_driver_regress.py",
    "irq-regress": ROOT / "kdi_irq_regress.py",
    "bringup-regress": ROOT / "bringup_regress.py",
    "bringup-ui": ROOT / "bringup_ui.py",
    "triage-bundle": ROOT / "triage_bundle.py",
    "triage-replay": ROOT / "triage_replay.py",
    "profile-compare": ROOT / "driver_profile_compare.py",
    "profile-regress": ROOT / "driver_profile_compare_regress.py",
}


def run_process_result(cmd: list[str], cmd_name: str, extra_args: list[str]) -> dict:
    proc = subprocess.run(cmd, capture_output=True, text=True)
    result = {
        "ok": proc.returncode == 0,
        "cmd": cmd_name,
        "args": extra_args,
        "exit_code": proc.returncode,
        "stdout": proc.stdout,
        "stderr": proc.stderr,
    }
    try:
        result["stdout_json"] = json.loads(proc.stdout) if proc.stdout.strip() else None
    except Exception:
        result["stdout_json"] = None
    return result


def run_process(cmd: list[str], cmd_name: str, extra_args: list[str], json_mode: bool) -> int:
    if not json_mode:
        return subprocess.call(cmd)
    result = run_process_result(cmd, cmd_name, extra_args)
    print(json.dumps(result, ensure_ascii=True))
    return int(result["exit_code"])


def run_tool(tool: str, extra_args: list[str], json_mode: bool) -> int:
    script = TOOLS[tool]
    if not script.exists():
        print(f"error: missing tool {script}", file=sys.stderr)
        return 2
    cmd = [sys.executable, str(script)] + extra_args
    return run_process(cmd, tool, extra_args, json_mode)


def run_demo(extra_args: list[str], json_mode: bool) -> int:
    script = ROOT / "vm32_demo.sh"
    if not script.exists():
        print(f"error: missing demo script {script}", file=sys.stderr)
        return 2
    cmd = ["bash", str(script)] + extra_args
    return run_process(cmd, "demo", extra_args, json_mode)


def run_named_command_result(cmd_name: str, extra_args: list[str]) -> dict:
    if cmd_name == "demo":
        script = ROOT / "vm32_demo.sh"
        if not script.exists():
            return {
                "ok": False,
                "cmd": cmd_name,
                "args": extra_args,
                "exit_code": 2,
                "stdout": "",
                "stderr": f"error: missing demo script {script}\n",
                "stdout_json": None,
            }
        return run_process_result(["bash", str(script)] + extra_args, cmd_name, extra_args)

    script = TOOLS.get(cmd_name)
    if script is None:
        return {
            "ok": False,
            "cmd": cmd_name,
            "args": extra_args,
            "exit_code": 2,
            "stdout": "",
            "stderr": f"error: unknown vm32 command '{cmd_name}'\n",
            "stdout_json": None,
        }
    if not script.exists():
        return {
            "ok": False,
            "cmd": cmd_name,
            "args": extra_args,
            "exit_code": 2,
            "stdout": "",
            "stderr": f"error: missing tool {script}\n",
            "stdout_json": None,
        }
    return run_process_result([sys.executable, str(script)] + extra_args, cmd_name, extra_args)


def parse_batch_file(path: str) -> list[tuple[int, list[str]]]:
    steps = []
    with open(path, "r", encoding="utf-8") as f:
        for lineno, raw in enumerate(f, start=1):
            line = raw.strip()
            if not line or line.startswith("#") or line.startswith(";"):
                continue
            toks = shlex.split(line)
            if toks:
                steps.append((lineno, toks))
    return steps


def run_batch(path: str, keep_going: bool, json_mode: bool) -> int:
    steps = parse_batch_file(path)
    results = []
    rc = 0

    for lineno, toks in steps:
        cmd_name = toks[0]
        extra_args = toks[1:]
        result = run_named_command_result(cmd_name, extra_args)
        result["line"] = lineno
        results.append(result)

        if not json_mode:
            print(f"[batch:{lineno}] vm32 {cmd_name} {' '.join(extra_args)}", flush=True)
            if result["stdout"]:
                sys.stdout.write(result["stdout"])
                sys.stdout.flush()
            if result["stderr"]:
                sys.stdout.write(result["stderr"])
                sys.stdout.flush()
            if not result["ok"]:
                print(f"[batch:{lineno}] failed rc={result['exit_code']}", flush=True)

        if not result["ok"]:
            rc = int(result["exit_code"])
            if not keep_going:
                break

    if json_mode:
        print(json.dumps({
            "ok": rc == 0,
            "cmd": "batch",
            "args": [path],
            "exit_code": rc,
            "steps_total": len(steps),
            "steps_executed": len(results),
            "results": results,
        }, ensure_ascii=True))
    return rc


def main() -> int:
    parser = argparse.ArgumentParser(
