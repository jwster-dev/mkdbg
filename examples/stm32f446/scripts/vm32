    p_batch.add_argument("--keep-going", action="store_true", help="continue after failures")

    p_board = sub.add_parser("board-regress", help="run on-board serial regression workflow")
    p_board.add_argument("--port", required=True, help="serial port, e.g. /dev/cu.usbmodemXXXX")
    p_board.add_argument("--baud", type=int, help="UART baud rate")
    p_board.add_argument("--char-delay-ms", type=float, help="per-char TX delay in ms")
    p_board.add_argument("--retries", type=int, help="retry count per step on mismatch")
    p_board.add_argument("--no-reset", action="store_true", help="skip OpenOCD reset before test")
    p_board.add_argument("--skip-mpu-overflow", action="store_true", help="skip final crash scenario")
    p_board.add_argument("--inner-json", action="store_true", help="pass --json to board_regress.py")

    p_sonic = sub.add_parser("sonic-regress", help="run on-board Sonic functional regression workflow")
    p_sonic.add_argument("--port", required=True, help="serial port, e.g. /dev/cu.usbmodemXXXX")
    p_sonic.add_argument("--baud", type=int, help="UART baud rate")
    p_sonic.add_argument("--char-delay-ms", type=float, help="per-char TX delay in ms")
    p_sonic.add_argument("--retries", type=int, help="retry count per step on mismatch")
    p_sonic.add_argument("--no-reset", action="store_true", help="skip OpenOCD reset before test")
    p_sonic.add_argument("--inner-json", action="store_true", help="pass --json to sonic_regress.py")

    p_kdi = sub.add_parser("kdi-regress", help="run on-board KDI driver lifecycle regression workflow")
    p_kdi.add_argument("--port", required=True, help="serial port, e.g. /dev/cu.usbmodemXXXX")
    p_kdi.add_argument("--baud", type=int, help="UART baud rate")
    p_kdi.add_argument("--char-delay-ms", type=float, help="per-char TX delay in ms")
    p_kdi.add_argument("--retries", type=int, help="retry count per step on mismatch")
    p_kdi.add_argument("--no-reset", action="store_true", help="skip OpenOCD reset before test")
    p_kdi.add_argument("--flash", action="store_true", help="build and flash firmware before test")
    p_kdi.add_argument("--flash-skip-build", action="store_true", help="with --flash, skip build and only flash existing ELF")
    p_kdi.add_argument("--no-auto-flash-stale", action="store_true", help="disable auto flash when KDI preflight detects stale firmware")
    p_kdi.add_argument("--inner-json", action="store_true", help="pass --json to kdi_driver_regress.py")

    p_irq = sub.add_parser("irq-regress", help="run on-board KDI IRQ/deferred-work regression workflow")
    p_irq.add_argument("--port", required=True, help="serial port, e.g. /dev/cu.usbmodemXXXX")
    p_irq.add_argument("--baud", type=int, help="UART baud rate")
    p_irq.add_argument("--char-delay-ms", type=float, help="per-char TX delay in ms")
    p_irq.add_argument("--retries", type=int, help="retry count per step on mismatch")
    p_irq.add_argument("--no-reset", action="store_true", help="skip OpenOCD reset before test")
    p_irq.add_argument("--flash", action="store_true", help="build and flash firmware before test")
    p_irq.add_argument("--flash-skip-build", action="store_true", help="with --flash, skip build and only flash existing ELF")
    p_irq.add_argument("--no-auto-flash-stale", action="store_true", help="disable auto flash when KDI preflight detects stale firmware")
    p_irq.add_argument("--inner-json", action="store_true", help="pass --json to kdi_irq_regress.py")

    p_bringup = sub.add_parser("bringup-regress", help="run on-board bring-up phase regression workflow")
    p_bringup.add_argument("--port", required=True, help="serial port, e.g. /dev/cu.usbmodemXXXX")
    p_bringup.add_argument("--baud", type=int, help="UART baud rate")
    p_bringup.add_argument("--char-delay-ms", type=float, help="per-char TX delay in ms")
    p_bringup.add_argument("--retries", type=int, help="retry count per step on mismatch")
    p_bringup.add_argument("--no-reset", action="store_true", help="skip OpenOCD reset before test")
    p_bringup.add_argument("--flash", action="store_true", help="build and flash firmware before test")
    p_bringup.add_argument("--flash-skip-build", action="store_true", help="with --flash, skip build and only flash existing ELF")
    p_bringup.add_argument("--no-auto-flash-stale", action="store_true", help="disable auto flash when bringup preflight detects stale firmware")
    p_bringup.add_argument("--inner-json", action="store_true", help="pass --json to bringup_regress.py")

