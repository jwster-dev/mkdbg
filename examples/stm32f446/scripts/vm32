    p_bringup_ui.add_argument("--port", help="serial port for live bundle capture")
    p_bringup_ui.add_argument("--bundle-json", help="existing triage bundle json path")
    p_bringup_ui.add_argument("--source-log", help="existing snapshot/bringup log path")
